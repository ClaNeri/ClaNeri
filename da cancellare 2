import re
import time
from datetime import datetime
from html import escape
from urllib.parse import quote

from selenium import webdriver
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.common.by import By
from webdriver_manager.chrome import ChromeDriverManager


def extract_fortios_version_from_config(config_path: str) -> str | None:
    with open(config_path, "r", encoding="utf-8", errors="ignore") as f:
        content = f.read()

    patterns = [
        r"config-version=.*?-(\d+\.\d+\.\d+)-",
        r"\b(v?\d+\.\d+\.\d+)\b",
    ]

    for pattern in patterns:
        match = re.search(pattern, content, re.IGNORECASE)
        if match:
            return match.group(1).lower().replace("v", "")

    return None


def build_fortiguard_url(version: str) -> str:
    base = "https://www.fortiguard.com/psirt"
    return (
        f"{base}?filter=1"
        f"&product=FortiOS-6K7K%2CFortiOS"
        f"&version={quote(version)}"
        f"&severity=5"
        f"&severity=4"
        f"&keyword="
    )

def get_driver():
    options = Options()
    # options.add_argument("--headless=new")  # enable later if you want
    options.add_argument("--window-size=1800,2200")
    options.add_argument("--disable-gpu")
    options.add_argument("--no-sandbox")
    options.add_argument("--disable-dev-shm-usage")
    options.add_argument("--disable-notifications")
    options.add_argument("--disable-extensions")
    options.add_argument("--remote-allow-origins=*")

    driver = webdriver.Chrome(
        service=Service(ChromeDriverManager().install()),
        options=options
    )
    return driver


def find_best_card_container(element):
    """
    Go up in the DOM and try to find the real vulnerability card.
    """
    current = element

    for _ in range(8):
        try:
            current = current.find_element(By.XPATH, "./..")
            text = current.text.strip()

            if not text:
                continue

            has_ir = "FG-IR-" in text
            has_severity = bool(re.search(r"\b(Critical|High|Medium|Low)\b", text, re.IGNORECASE))

            # reject very large wrapper blocks
            too_big = len(text) > 2500
            has_page_title = "PSIRT Advisories" in text

            if has_ir and has_severity and not too_big and not has_page_title:
                return current

        except Exception:
            break

    return None
def extract_date_from_text(card_text: str) -> str:
    """
    Try to find a date in the card text.
    Example formats:
    Jan 9, 2026
    February 11, 2025
    """
    patterns = [
        r"\b(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]* \d{1,2}, \d{4}\b",
        r"\b\d{4}-\d{2}-\d{2}\b",
    ]

    for pattern in patterns:
        match = re.search(pattern, card_text, re.IGNORECASE)
        if match:
            return match.group(0)

    return "N/A"


def parse_date_for_sort(date_str: str):
    """
    Convert date text into datetime for sorting.
    If parsing fails, return very old date.
    """
    if not date_str or date_str == "N/A":
        return datetime.min

    formats = [
        "%b %d, %Y",   # Jan 9, 2026
        "%B %d, %Y",   # January 9, 2026
        "%Y-%m-%d",    # 2026-01-09
    ]

    for fmt in formats:
        try:
            return datetime.strptime(date_str, fmt)
        except ValueError:
            continue

    return datetime.min

def extract_findings_from_cards(driver) -> list[dict]:
    findings = {}
    seen_cards = set()

    ir_elements = driver.find_elements(
        By.XPATH,
        "//div[contains(.,'FG-IR-') and not(contains(.,'PSIRT Advisories'))]"
    )

    for el in ir_elements:
        try:
            text = el.text.strip()
            ir_match = re.search(r"(FG-IR-\d{2}-\d+)", text)
            if not ir_match:
                continue

            ir = ir_match.group(1)

            card = find_best_card_container(el)
            if not card:
                continue

            card_text = card.text.strip()
            if not card_text or card_text in seen_cards:
                continue

            seen_cards.add(card_text)

            if "PSIRT Advisories" in card_text:
                continue

            severity_match = re.search(r"\b(Critical|High|Medium|Low)\b", card_text, re.IGNORECASE)
            if not severity_match:
                continue

            severity = severity_match.group(1).title()

            if severity not in ["High", "Critical"]:
                continue

            cves = re.findall(r"(CVE-\d{4}-\d+)", card_text)
            date_found = extract_date_from_text(card_text)

            lines = [x.strip() for x in card_text.splitlines() if x.strip()]
            title = lines[0] if lines else ir

            if not title.startswith("FG-IR-"):
                continue

            findings[ir] = {
                "ir": ir,
                "cves": list(dict.fromkeys(cves)) if cves else ["N/A"],
                "severity": severity,
                "title": title,
                "published_date": date_found,
                "raw_text": card_text,
            }

        except Exception:
            continue

    return list(findings.values())


def go_to_next_page(driver) -> bool:
    """
    Click the next page button if it exists and is enabled.
    Return True if moved to next page, else False.
    """
    possible_xpaths = [
        "//a[contains(translate(., 'NEXT', 'next'), 'next')]",
        "//button[contains(translate(., 'NEXT', 'next'), 'next')]",
        "//li[contains(@class,'next')]/a",
        "//a[@aria-label='Next']",
        "//button[@aria-label='Next']",
    ]

    for xpath in possible_xpaths:
        try:
            elements = driver.find_elements(By.XPATH, xpath)

            for el in elements:
                if not el.is_displayed() or not el.is_enabled():
                    continue

                text = el.text.strip().lower()

                # skip disabled next buttons
                class_name = (el.get_attribute("class") or "").lower()
                aria_disabled = (el.get_attribute("aria-disabled") or "").lower()

                if "disabled" in class_name or aria_disabled == "true":
                    continue

                driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", el)
                time.sleep(1)
                driver.execute_script("arguments[0].click();", el)
                time.sleep(3)
                return True

        except Exception:
            continue

    return False

def collect_all_high_critical(driver, max_pages=10, pause=2):
    all_findings = {}
    visited_pages = 0

    while visited_pages < max_pages:
        time.sleep(pause)

        current_findings = extract_findings_from_cards(driver)

        for item in current_findings:
            all_findings[item["ir"]] = item

        visited_pages += 1

        moved = go_to_next_page(driver)
        if not moved:
            break

    return sorted(all_findings.values(), key=lambda x: x["ir"])

