def sort_findings_by_severity(findings: list[dict]) -> list[dict]:
    severity_order = {
        "Critical": 0,
        "High": 1,
    }

    return sorted(
        findings,
        key=lambda x: (
            severity_order.get(x["severity"], 99),
            -parse_date_for_sort(x.get("published_date", "N/A")).timestamp()
            if parse_date_for_sort(x.get("published_date", "N/A")) != datetime.min
            else float("inf"),
            x["ir"]
        )
    )

